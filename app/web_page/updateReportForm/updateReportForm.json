    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.thesis && $data.context ){",
        "\treturn {",
        "\t\t//map thesis variable to expected task contract input",
        "\t\tthesisInput: {",
        "\t\t\treport: $data.thesis.report !== undefined ? $data.thesis.report : null",
        "\t\t},",
        "\t\tthesisDocumentInputDocumentInput: {",
        "\t\t\tid: $data.context.thesisDocumentInput_ref && $data.context.thesisDocumentInput_ref.id ? $data.context.thesisDocumentInput_ref.id.toString() : null,",
        "\t\t\tfilename: $data.context.thesisDocumentInput_ref.newValue && $data.context.thesisDocumentInput_ref.newValue.filename ? $data.context.thesisDocumentInput_ref.newValue.filename : null,",
        "\t\t\ttempPath: $data.context.thesisDocumentInput_ref.newValue && $data.context.thesisDocumentInput_ref.newValue.tempPath ? $data.context.thesisDocumentInput_ref.newValue.tempPath : null,",
        "\t\t\tcontentType: $data.context.thesisDocumentInput_ref.newValue && $data.context.thesisDocumentInput_ref.newValue.contentType ? $data.context.thesisDocumentInput_ref.newValue.contentType : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "thesis" : {
      "type" : "url",
      "value" : [
        "../{{context.thesis_ref.link}}"
      ],
      "exposed" : false
    },
